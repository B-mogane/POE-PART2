<Window x:Class="Bot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bot"
        mc:Ignorable="d"
        Title="MainWindow" Height="501" Width="863">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#0a0f1a" CornerRadius="8" Margin="5" Padding="10">
            <TextBlock x:Name="AsciiLogo"
                       FontFamily="Consolas, Courier New, monospace"
                       FontSize="9"
                       Foreground="#4c8cff"
                       TextAlignment="Center"
                       xml:space="preserve">
           ▄████████  ▄█   ▄█          ▄████████    ▄████████ 
          ███    ███ ███  ███         ███    ███   ███    ███ 
          ███    █▀  ███▌ ███         ███    █▀    ███    █▀  
          ███        ███▌ ███        ▄███▄▄▄       ███        
        ▀███████████ ███▌ ███       ▀▀███▀▀▀     ▀███████████ 
                 ███ ███  ███         ███    █▄           ███ 
           ▄█    ███ ███  ███▌    ▄   ███    ███    ▄█    ███ 
         ▄████████▀  █▀   █████▄▄██   ██████████  ▄████████▀  
                          ▀                                     
                 CYBERSECURITY AWARENESS BOT
            </TextBlock>
        </Border>

        <Border Grid.Row="1" Background="#2a2a2a" CornerRadius="6" Margin="5" Padding="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Name: " Foreground="#aaa"/>
                <TextBlock x:Name="TxtName" Text="?" Foreground="#4caf50" Margin="0,0,15,0"/>
                <TextBlock Text=" Interest: " Foreground="#aaa"/>
                <TextBlock x:Name="TxtInterest" Text="?" Foreground="#ffa726"/>
            </StackPanel>
        </Border>

        <ListBox x:Name="ChatList" Grid.Row="2" Background="#2d2d2d" BorderBrush="#444" 
                 Foreground="#eee" FontSize="13" Margin="5"/>

        <Border Grid.Row="3" Background="#2a2a2a" CornerRadius="6" Margin="5" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InputBox" Background="#3a3a3a" Foreground="White" 
                         KeyDown="InputBox_KeyDown" FontSize="14" Padding="6"/>
                <Button Grid.Column="1" Content="Send" Click="Send_Click" 
                        Background="#2E7D32" Foreground="White" FontWeight="Bold"/>
            </Grid>
        </Border>
    </Grid>

</Window>
